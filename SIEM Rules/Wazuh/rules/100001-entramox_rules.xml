    <description>Entramox: PDM user disabled — $(userid)</description>
    <group>pdm,user,entramox,</group>
  </rule>

  <rule id="2803" level="5">
    <decoded_as>entramox-reconciler-pdm-acl-set</decoded_as>
    <description>Entramox: PDM ACL assigned — $(userid) role=$(role) @ $(path)</description>
    <group>pdm,acl,entramox,</group>
  </rule>

  <rule id="2804" level="10">
    <decoded_as>entramox-reconciler-pdm-error</decoded_as>
