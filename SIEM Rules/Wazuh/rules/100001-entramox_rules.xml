<!-- ================= REMOTE API ERRORS (PBS + PDM shared) (v2.5) ================= -->
<group name="local,entramox,remote_api,">

  <rule id="2810" level="9">
    <decoded_as>entramox-reconciler-remote-api-http-error</decoded_as>
    <description>Entramox: Remote API HTTP error — $(http_method) $(url) status=$(status)</description>
    <group>remote_api,http,error,entramox,</group>
  </rule>

  <!-- 401/403 specifically — credential or permission problem -->
  <rule id="2811" level="12">
    <if_sid>2810</if_sid>
    <field name="status">^40[13]$</field>
    <description>Entramox: Remote API authentication/authorisation failure — $(http_method) $(url) status=$(status)</description>
    <mitre><id>T1552</id></mitre>
    <group>remote_api,auth,error,entramox,</group>
  </rule>

  <rule id="2812" level="8">
    <decoded_as>entramox-reconciler-remote-api-error</decoded_as>
    <description>Entramox: Remote API connection failed — $(http_method) $(url): $(err)</description>
    <group>remote_api,connectivity,error,entramox,</group>
  </rule>

</group>

<!-- ================= JSON AUDIT LOG (v2.5) ================= -->
<!-- These rules match events from /var/log/entramoxreconciler/audit.log
     which is read as log_format=json. Wazuh extracts JSON fields into
     data.* automatically; rules filter on data.event.              -->
<group name="local,entramox,audit_log,">

  <rule id="2820" level="7">
    <decoded_as>entramox-audit</decoded_as>
    <field name="data.event">^USER_CREATED$</field>
    <description>Entramox Audit: Linux user created — $(data.user)</description>
    <group>audit,user,provisioning,entramox,</group>
  </rule>

  <rule id="2821" level="9">
    <decoded_as>entramox-audit</decoded_as>
    <field name="data.event">^SUDO_GRANTED$</field>
    <description>Entramox Audit: Sudo granted — $(data.user)</description>
    <mitre><id>T1548</id></mitre>
    <group>audit,sudo,privilege_escalation,entramox,</group>
  </rule>

  <rule id="2822" level="9">
    <decoded_as>entramox-audit</decoded_as>
    <field name="data.event">^TIERED_ACCOUNT_CREATED$</field>
    <description>Entramox Audit: Tiered account created — $(data.tiered_user) for base $(data.base_user)</description>
    <mitre><id>T1548</id><id>T1136.001</id></mitre>
    <group>audit,tiered,privilege_escalation,entramox,</group>
  </rule>

  <rule id="2823" level="8">
    <decoded_as>entramox-audit</decoded_as>
    <field name="data.event">^TIERED_ACCOUNT_DELETED$</field>
    <description>Entramox Audit: Tiered account removed — $(data.tiered_user)</description>
    <group>audit,tiered,deprovisioning,entramox,</group>
  </rule>

  <!-- ================================================================
       INTEGRITY CHECKER — entramox_check.sh events (v2.5)
       Level mapping (sev 2 / high-critical):
         14 = script binary tampered (hash mismatch)  → CRITICAL
         13 = symlink / wrong owner / bad perms        → CRITICAL
         10 = env or key file checksum changed         → WARNING (possible re-config)
          8 = monitored file missing                   → WARNING
       ================================================================ -->

  <!-- Script binary checksum mismatch — highest severity -->
  <rule id="2830" level="14">
    <decoded_as>entramox-checker-script-tampered</decoded_as>
    <description>Entramox Integrity: script checksum mismatch — possible binary tampering ($(path))</description>
    <mitre><id>T1195</id><id>T1574</id></mitre>
    <group>entramox,integrity,tampering,</group>
  </rule>

  <!-- Symlink where file expected — redirection / hijack attempt -->
  <rule id="2831" level="13">
    <decoded_as>entramox-checker-symlink-refused</decoded_as>
    <description>Entramox Integrity: symlink detected for monitored path — possible hijack ($(path))</description>
    <mitre><id>T1574.010</id></mitre>
    <group>entramox,integrity,tampering,</group>
  </rule>

  <!-- File not owned by root -->
  <rule id="2832" level="13">
    <decoded_as>entramox-checker-not-owned-root</decoded_as>
    <description>Entramox Integrity: monitored file not owned by root — uid=$(uid) path=$(path)</description>
    <mitre><id>T1222</id></mitre>
    <group>entramox,integrity,tampering,</group>
  </rule>

  <!-- Permissions too permissive -->
  <rule id="2833" level="13">
    <decoded_as>entramox-checker-perms-too-broad</decoded_as>
    <description>Entramox Integrity: permissions too broad on monitored file — mode=$(mode) path=$(path)</description>
    <mitre><id>T1222</id></mitre>
    <group>entramox,integrity,tampering,</group>
  </rule>

  <!-- Env file checksum changed — potential credential swap -->
  <rule id="2834" level="10">
    <decoded_as>entramox-checker-env-changed</decoded_as>
    <description>Entramox Integrity: env file checksum changed — verify intentional ($(path))</description>
    <mitre><id>T1552.001</id></mitre>
    <group>entramox,integrity,config_change,</group>
  </rule>

  <!-- Key file checksum changed -->
  <rule id="2835" level="10">
    <decoded_as>entramox-checker-key-changed</decoded_as>
    <description>Entramox Integrity: key file checksum changed — possible credential rotation or tamper ($(path))</description>
    <mitre><id>T1552.001</id></mitre>
    <group>entramox,integrity,config_change,</group>
  </rule>

  <!-- Missing monitored file -->
  <rule id="2836" level="8">
    <decoded_as>entramox-checker-missing-file</decoded_as>
    <description>Entramox Integrity: monitored file missing — $(path)</description>
    <group>entramox,integrity,misconfig,</group>
  </rule>

  <!-- Composite: multiple integrity failures in same run (escalation) -->
  <rule id="2837" level="14" frequency="2" timeframe="60">
    <if_matched_sid>2831,2832,2833</if_matched_sid>
    <description>Entramox Integrity: multiple file tampering indicators detected in 60s — possible active attack</description>
    <mitre><id>T1574</id></mitre>
    <group>entramox,integrity,tampering,</group>
  </rule>

  <!-- ================================================================ -->

  <rule id="2824" level="6">
    <decoded_as>entramox-audit</decoded_as>
    <field name="data.event">^PBS_USER_CREATED$</field>
    <description>Entramox Audit: PBS user provisioned — $(data.userid)</description>
    <group>audit,pbs,provisioning,entramox,</group>
  </rule>

  <rule id="2825" level="7">
    <decoded_as>entramox-audit</decoded_as>
    <field name="data.event">^PBS_USER_TOGGLED$</field>
    <description>Entramox Audit: PBS user state changed — $(data.userid) enabled=$(data.enabled)</description>
    <group>audit,pbs,entramox,</group>
  </rule>

  <rule id="2826" level="6">
    <decoded_as>entramox-audit</decoded_as>
    <field name="data.event">^PDM_USER_CREATED$</field>
    <description>Entramox Audit: PDM user provisioned — $(data.userid)</description>
    <group>audit,pdm,provisioning,entramox,</group>
  </rule>

  <rule id="2827" level="7">
    <decoded_as>entramox-audit</decoded_as>
    <field name="data.event">^PDM_USER_TOGGLED$</field>
    <description>Entramox Audit: PDM user state changed — $(data.userid) enabled=$(data.enabled)</description>
    <group>audit,pdm,entramox,</group>
  </rule>

</group>
