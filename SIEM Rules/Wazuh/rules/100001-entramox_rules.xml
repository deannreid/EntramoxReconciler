    <description>Entramox: PBS user enabled — $(userid)</description>
    <group>pbs,user,entramox,</group>
  </rule>

  <rule id="2792" level="6">
    <decoded_as>entramox-reconciler-pbs-user-toggled</decoded_as>
    <field name="enabled">^0$</field>
    <description>Entramox: PBS user disabled — $(userid)</description>
    <group>pbs,user,entramox,</group>
  </rule>

  <rule id="2793" level="5">
    <decoded_as>entramox-reconciler-pbs-acl-set</decoded_as>
    <description>Entramox: PBS ACL assigned — $(userid) role=$(role) @ $(path)</description>
    <group>pbs,acl,entramox,</group>
  </rule>

  <rule id="2794" level="10">
    <decoded_as>entramox-reconciler-pbs-error</decoded_as>
    <description>Entramox: PBS operation failed — $(operation) for $(userid)</description>
    <group>pbs,error,entramox,</group>
  </rule>

  <rule id="2795" level="12">
    <decoded_as>entramox-reconciler-pbs-auth-missing</decoded_as>
    <description>Entramox: PBS authentication credentials missing or invalid — PBS sync will not run</description>
    <mitre><id>T1552</id></mitre>
    <group>pbs,auth,misconfig,entramox,</group>
  </rule>

</group>

<!-- ================= PROXMOX DATACENTER MANAGER (PDM) (v2.5) ================= -->
<group name="local,entramox,proxmox_datacenter,">

  <rule id="2800" level="6">
