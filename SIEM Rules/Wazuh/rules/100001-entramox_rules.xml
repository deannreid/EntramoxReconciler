    <group>pdm,error,entramox,</group>
  </rule>

  <rule id="2805" level="12">
    <decoded_as>entramox-reconciler-pdm-auth-missing</decoded_as>
    <description>Entramox: PDM authentication credentials missing or invalid — PDM sync will not run</description>
